---
import {
  getDiscoveredTargets,
  getImagesForFolder,
  getDownloadsForFolder,
  getObservationsForFolder,
  getAnnotatedImageForFolder
} from "../../lib/r2-images.js";

export async function getStaticPaths() {
  const targets = await getDiscoveredTargets();

  return await Promise.all(
    targets.map(async (target) => {
      const images = await getImagesForFolder(target.folder);
      const downloads = await getDownloadsForFolder(target.folder);
      const observationData = await getObservationsForFolder(target.folder);
      const annotatedImage = await getAnnotatedImageForFolder(target.folder);

      return {
        params: { slug: target.slug },
        props: {
          target: {
            ...target,
            images,
            downloads,
            annotatedImage,
            observations: observationData.observations,
            observationSummary: observationData.summary
          }
        }
      };
    })
  );
}

const { target } = Astro.props;
const firstImage = target.images?.[0];

const quickFacts = [
  ["Object type", target.objectType],
  ["Constellation", target.constellation],
  ["Distance", target.distance],
  ["Apparent magnitude", target.apparentMagnitude],
  ["Diameter", target.diameter],
  ["Discovered", target.discovered]
].filter(([, value]) => value);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{target.name} | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a class="back" href="/">← Back to gallery</a>

      <article class="target">
        <div class="image-panel">
          {firstImage ? (
            <>
              <img id="mainImage" src={firstImage.url} alt={target.name} title="Click to enlarge" />

              <p id="imageLabel" class="image-label">{firstImage.label}</p>

              {target.annotatedImage && (
                <div class="view-toggle">
                  <button id="originalViewBtn" class="active" type="button">Original</button>
                  <button id="annotatedViewBtn" type="button">Annotated</button>
                </div>
              )}

              {target.images.length > 1 && (
                <>
                  <div class="controls">
                    <button id="prevBtn" type="button">←</button>
                    <span id="counter">1 / {target.images.length}</span>
                    <button id="nextBtn" type="button">→</button>
                  </div>

                  <div class="thumbnails">
                    {target.images.map((img, i) => (
                      <img
                        src={img.url}
                        alt={img.label}
                        class={`thumb ${i === 0 ? "active" : ""}`}
                        data-index={i}
                      />
                    ))}
                  </div>
                </>
              )}
            </>
          ) : (
            <div class="missing-image">No photos found in this Cloudflare folder yet.</div>
          )}
        </div>

        <div class="content">
          <p class="category">{target.category}</p>

          <h1>
            {target.catalog ? `${target.catalog}: ${target.name}` : target.name}
          </h1>

          <p class="description">{target.description}</p>

          <section class="info-grid">
            {target.dateCaptured && (
              <div class="info-card">
                <span>Date captured</span>
                <strong>{target.dateCaptured}</strong>
              </div>
            )}

            {target.equipment && (
              <div class="info-card">
                <span>Equipment</span>
                <strong>{target.equipment}</strong>
              </div>
            )}

            {target.location && (
              <div class="info-card">
                <span>Location</span>
                <strong>{target.location}</strong>
              </div>
            )}

            {target.observationSummary?.sessions > 0 && (
              <div class="info-card">
                <span>Total integration</span>
                <strong>{target.observationSummary.totalHours} hours</strong>
              </div>
            )}
          </section>

          {quickFacts.length > 0 && (
            <section class="extra">
              <h2>Quick Facts</h2>
              <div class="facts-grid">
                {quickFacts.map(([label, value]) => (
                  <div class="fact-card">
                    <span>{label}</span>
                    <strong>{value}</strong>
                  </div>
                ))}
              </div>
            </section>
          )}

          {target.whatYouAreSeeing && (
            <section class="extra">
              <h2>What you're looking at</h2>
              <p>{target.whatYouAreSeeing}</p>
            </section>
          )}

          {target.whyItIsInteresting && (
            <section class="extra">
              <h2>Why it is interesting</h2>
              <p>{target.whyItIsInteresting}</p>
            </section>
          )}

          {target.captureNotes && (
            <section class="extra">
              <h2>How I captured it</h2>
              <p>{target.captureNotes}</p>
            </section>
          )}

          {target.observationSummary?.sessions > 0 && (
            <section class="extra">
              <h2>Observation Log</h2>
              <p>
                Total integration time:
                <strong>{target.observationSummary.totalHours} hours</strong>
                across {target.observationSummary.sessions} sessions.
              </p>

              <div class="download-list">
                {target.observations.map((item) => (
                  <div class="download-card">
                    <div>
                      <strong>{item.date} — {item.minutes} minutes</strong>
                      <span>{item.subSeconds} second exposures</span>
                      {item.notes && <p>{item.notes}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          {target.downloads?.length > 0 && (
            <section class="downloads">
              <h2>Download raw files</h2>
              <p>Want to try processing this target yourself? Download the original data files below.</p>

              <div class="download-list">
                {target.downloads.map((file) => (
                  <a class="download-card" href={file.url} download>
                    <div>
                      <strong>{file.label}</strong>
                      <span>{file.type} file</span>
                    </div>
                    <span class="download-button">Download</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </article>
    </main>

    {target.images?.length > 0 && (
      <script define:vars={{ images: target.images, annotatedImage: target.annotatedImage }}>
        let currentIndex = 0;
        let showingAnnotated = false;

        const mainImage = document.getElementById("mainImage");
        const imageLabel = document.getElementById("imageLabel");
        const counter = document.getElementById("counter");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const thumbs = document.querySelectorAll(".thumb");

        const originalViewBtn = document.getElementById("originalViewBtn");
        const annotatedViewBtn = document.getElementById("annotatedViewBtn");

        function getCurrentImage() {
          return showingAnnotated && annotatedImage ? annotatedImage : images[currentIndex];
        }

        function updateButtons() {
          if (!originalViewBtn || !annotatedViewBtn) return;
          originalViewBtn.classList.toggle("active", !showingAnnotated);
          annotatedViewBtn.classList.toggle("active", showingAnnotated);
        }

        function updateDisplay() {
          const img = getCurrentImage();

          mainImage.src = img.url;
          mainImage.alt = img.label;
          imageLabel.textContent = img.label;

          if (counter) {
            counter.textContent = showingAnnotated ? "Annotated" : `${currentIndex + 1} / ${images.length}`;
          }

          thumbs.forEach((thumb) => thumb.classList.remove("active"));
          if (!showingAnnotated && thumbs[currentIndex]) {
            thumbs[currentIndex].classList.add("active");
          }

          updateButtons();
        }

        function showImage(index) {
          currentIndex = index;
          showingAnnotated = false;
          updateDisplay();
        }

        if (originalViewBtn) {
          originalViewBtn.addEventListener("click", () => {
            showingAnnotated = false;
            updateDisplay();
          });
        }

        if (annotatedViewBtn) {
          annotatedViewBtn.addEventListener("click", () => {
            showingAnnotated = true;
            updateDisplay();
          });
        }

        thumbs.forEach((thumb) => {
          thumb.addEventListener("click", () => {
            showImage(Number(thumb.dataset.index));
          });
        });

        if (prevBtn && nextBtn) {
          prevBtn.addEventListener("click", () => {
            showImage((currentIndex - 1 + images.length) % images.length);
          });

          nextBtn.addEventListener("click", () => {
            showImage((currentIndex + 1) % images.length);
          });
        }
      </script>
    )}
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #0c1222, #05070d);
    color: white;
  }

  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 32px 20px 48px;
  }

  .back {
    color: #9db7ff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 24px;
  }

  .target {
    background: rgba(18, 24, 39, 0.75);
    border: 1px solid rgba(125, 162, 255, 0.22);
    border-radius: 22px;
    overflow: hidden;
  }

  .image-panel {
    background: black;
  }

  #mainImage {
    width: 100%;
    max-height: 650px;
    object-fit: contain;
    display: block;
    background: black;
  }

  .missing-image {
    min-height: 260px;
    display: grid;
    place-items: center;
    color: #9db7ff;
    padding: 24px;
    text-align: center;
  }

  .image-label {
    text-align: center;
    font-size: 14px;
    color: #c7d2ea;
    margin: 0;
    padding: 10px 12px 12px;
    background: #05070d;
  }

  .view-toggle,
  .controls {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    background: #05070d;
  }

  .view-toggle button,
  .controls button {
    background: #121827;
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    padding: 8px 14px;
    border-radius: 999px;
    cursor: pointer;
  }

  .view-toggle button.active {
    background: #26335f;
    border-color: #7da2ff;
  }

  #counter {
    color: #c7d2ea;
    font-size: 14px;
    min-width: 80px;
    text-align: center;
    align-self: center;
  }

  .thumbnails {
    display: flex;
    gap: 8px;
    padding: 12px;
    overflow-x: auto;
    background: #05070d;
  }

  .thumb {
    height: 64px;
    width: 88px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    opacity: 0.65;
    border: 2px solid transparent;
    flex: 0 0 auto;
    background: black;
  }

  .thumb.active {
    border-color: #7da2ff;
    opacity: 1;
  }

  .content {
    padding: 26px;
  }

  .category {
    color: #9db7ff;
    font-size: 14px;
    margin: 0 0 10px;
  }

  h1 {
    font-size: 38px;
    margin: 0 0 18px;
  }

  .description {
    color: #d8deee;
    font-size: 18px;
    line-height: 1.65;
    margin-bottom: 26px;
  }

  .info-grid,
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 28px;
  }

  .info-card,
  .fact-card {
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
  }

  .info-card span,
  .fact-card span {
    display: block;
    color: #9db7ff;
    font-size: 13px;
    margin-bottom: 6px;
  }

  .info-card strong,
  .fact-card strong {
    color: white;
    font-size: 15px;
  }

  .extra,
  .downloads {
    border-top: 1px solid rgba(125, 162, 255, 0.2);
    padding-top: 22px;
    margin-top: 22px;
  }

  .extra h2,
  .downloads h2 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .extra p,
  .downloads p {
    color: #c7d2ea;
    line-height: 1.6;
  }

  .download-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .download-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
    color: white;
    text-decoration: none;
  }

  .download-card span {
    color: #9db7ff;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }
  }
</style>