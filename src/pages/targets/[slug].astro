---
import targets from "../../data/targets.json";
import { getImagesForFolder, getDownloadsForFolder } from "../../lib/r2-images.js";

export async function getStaticPaths() {
  return await Promise.all(
    targets.map(async (target) => {
      const images = await getImagesForFolder(target.folder);
      const downloads = await getDownloadsForFolder(target.folder);

      return {
        params: { slug: target.slug },
        props: {
          target: {
            ...target,
            images,
            downloads
          }
        }
      };
    })
  );
}

const { target } = Astro.props;
const firstImage = target.images[0];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{target.name} | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a class="back" href="/">← Back to gallery</a>

      <article class="target">
        <div class="image-panel">
          {firstImage ? (
            <>
              <img id="mainImage" src={firstImage.url} alt={target.name} />

              <p id="imageLabel" class="image-label">
                {firstImage.label}
              </p>

              {target.images.length > 1 && (
                <>
                  <div class="controls">
                    <button id="prevBtn" type="button">←</button>
                    <span id="counter">1 / {target.images.length}</span>
                    <button id="nextBtn" type="button">→</button>
                  </div>

                  <div class="thumbnails">
                    {target.images.map((img, i) => (
                      <img
                        src={img.url}
                        alt={img.label}
                        class={`thumb ${i === 0 ? "active" : ""}`}
                        data-index={i}
                      />
                    ))}
                  </div>
                </>
              )}
            </>
          ) : (
            <div class="missing-image">
              No photos found in this Cloudflare folder yet.
            </div>
          )}
        </div>

        <div class="content">
          <p class="category">{target.category}</p>

          <h1>
            {target.catalog ? `${target.catalog}: ${target.name}` : target.name}
          </h1>

          <p class="description">{target.description}</p>

          <section class="info-grid">
            {target.dateCaptured && (
              <div class="info-card">
                <span>Date captured</span>
                <strong>{target.dateCaptured}</strong>
              </div>
            )}

            {target.equipment && (
              <div class="info-card">
                <span>Equipment</span>
                <strong>{target.equipment}</strong>
              </div>
            )}

            {target.location && (
              <div class="info-card">
                <span>Location</span>
                <strong>{target.location}</strong>
              </div>
            )}
          </section>

          <section class="extra">
            <h2>What you're looking at</h2>
            <p>{target.whatYouAreSeeing}</p>
          </section>

          <section class="extra">
            <h2>Why it is interesting</h2>
            <p>{target.whyItIsInteresting}</p>
          </section>

          <section class="extra">
            <h2>How I captured it</h2>
            <p>{target.captureNotes}</p>
          </section>

          {target.downloads.length > 0 && (
            <section class="downloads">
              <h2>Download raw files</h2>
              <p>
                Want to practice processing this target yourself? These files are available
                for download.
              </p>

              <div class="download-list">
                {target.downloads.map((file) => (
                  <a class="download-card" href={file.url} download>
                    <div>
                      <strong>{file.label}</strong>
                      <span>{file.type} file</span>
                    </div>
                    <span class="download-button">Download</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </article>
    </main>

    {target.images.length > 0 && (
      <script define:vars={{ images: target.images }}>
        let currentIndex = 0;

        const mainImage = document.getElementById("mainImage");
        const imageLabel = document.getElementById("imageLabel");
        const counter = document.getElementById("counter");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const thumbs = document.querySelectorAll(".thumb");

        function updateActiveThumb() {
          thumbs.forEach((thumb) => thumb.classList.remove("active"));
          if (thumbs[currentIndex]) thumbs[currentIndex].classList.add("active");
        }

        function showImage(index) {
          currentIndex = index;
          mainImage.src = images[currentIndex].url;
          mainImage.alt = images[currentIndex].label;

          if (imageLabel) imageLabel.textContent = images[currentIndex].label;
          if (counter) counter.textContent = `${currentIndex + 1} / ${images.length}`;

          updateActiveThumb();
        }

        thumbs.forEach((thumb) => {
          thumb.addEventListener("click", () => {
            showImage(Number(thumb.dataset.index));
          });
        });

        if (prevBtn && nextBtn) {
          prevBtn.addEventListener("click", () => {
            showImage((currentIndex - 1 + images.length) % images.length);
          });

          nextBtn.addEventListener("click", () => {
            showImage((currentIndex + 1) % images.length);
          });
        }

        updateActiveThumb();
      </script>
    )}
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #0c1222, #05070d);
    color: white;
  }

  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 32px 20px 48px;
  }

  .back {
    color: #9db7ff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 24px;
  }

  .target {
    background: rgba(18, 24, 39, 0.75);
    border: 1px solid rgba(125, 162, 255, 0.22);
    border-radius: 22px;
    overflow: hidden;
  }

  .image-panel {
    background: black;
  }

  #mainImage {
    width: 100%;
    max-height: 650px;
    object-fit: contain;
    display: block;
  }

  .missing-image {
    min-height: 260px;
    display: grid;
    place-items: center;
    color: #9db7ff;
    padding: 24px;
    text-align: center;
  }

  .image-label {
    text-align: center;
    font-size: 14px;
    color: #c7d2ea;
    margin: 0;
    padding: 10px 12px 12px;
    background: #05070d;
    border-top: 1px solid rgba(125, 162, 255, 0.12);
  }

  .controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background: #05070d;
    border-top: 1px solid rgba(125, 162, 255, 0.2);
  }

  .controls button {
    background: #121827;
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    padding: 9px 14px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 18px;
    min-width: 44px;
  }

  #counter {
    color: #c7d2ea;
    font-size: 14px;
    min-width: 60px;
    text-align: center;
  }

  .thumbnails {
    display: flex;
    gap: 8px;
    padding: 12px;
    overflow-x: auto;
    background: #05070d;
    border-top: 1px solid rgba(125, 162, 255, 0.12);
  }

  .thumb {
    height: 64px;
    width: 88px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    opacity: 0.65;
    border: 2px solid transparent;
    flex: 0 0 auto;
    background: black;
  }

  .thumb:hover {
    opacity: 1;
  }

  .thumb.active {
    border-color: #7da2ff;
    opacity: 1;
  }

  .content {
    padding: 26px;
  }

  .category {
    color: #9db7ff;
    font-size: 14px;
    margin: 0 0 10px;
  }

  h1 {
    font-size: 38px;
    margin: 0 0 18px;
  }

  .description {
    color: #d8deee;
    font-size: 18px;
    line-height: 1.65;
    margin-bottom: 26px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin: 0 0 28px;
  }

  .info-card {
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
  }

  .info-card span {
    display: block;
    color: #9db7ff;
    font-size: 13px;
    margin-bottom: 6px;
  }

  .extra,
  .downloads {
    border-top: 1px solid rgba(125, 162, 255, 0.2);
    padding-top: 22px;
    margin-top: 22px;
  }

  .extra h2,
  .downloads h2 {
    font-size: 22px;
    margin: 0 0 10px;
  }

  .extra p,
  .downloads p {
    color: #c7d2ea;
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
  }

  .download-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .download-card {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
    color: white;
    text-decoration: none;
  }

  .download-card strong {
    display: block;
    margin-bottom: 4px;
  }

  .download-card span {
    color: #9db7ff;
    font-size: 14px;
  }

  .download-button {
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    padding: 8px 12px;
    white-space: nowrap;
  }
</style>