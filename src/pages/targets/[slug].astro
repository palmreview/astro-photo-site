---
import {
  getDiscoveredTargets,
  getImagesForFolder,
  getDownloadsForFolder,
  getObservationsForFolder,
  getAnnotatedImageForFolder,
  getSkyMapForFolder
} from "../../lib/r2-images.js";

export async function getStaticPaths() {
  const targets = await getDiscoveredTargets();

  return await Promise.all(
    targets.map(async (target) => {
      const images = await getImagesForFolder(target.folder);
      const downloads = await getDownloadsForFolder(target.folder);
      const observationData = await getObservationsForFolder(target.folder);
      const annotatedImage = await getAnnotatedImageForFolder(target.folder);
      const skyMap = await getSkyMapForFolder(target.folder);

      return {
        params: { slug: target.slug },
        props: {
          target: {
            ...target,
            images,
            downloads,
            annotatedImage,
            skyMap,
            observations: observationData.observations,
            observationSummary: observationData.summary
          }
        }
      };
    })
  );
}

const { target } = Astro.props;
const firstImage = target.images?.[0];

const quickFacts = [
  ["Object type", target.objectType],
  ["Constellation", target.constellation],
  ["Distance", target.distance],
  ["Apparent magnitude", target.apparentMagnitude],
  ["Diameter", target.diameter],
  ["Discovered", target.discovered]
].filter(([, value]) => value);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{target.name} | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a class="back" href="/">← Back to gallery</a>

      <article class="target">
        <div class="image-panel">
          {firstImage ? (
            <>
              <img
                id="mainImage"
                src={firstImage.url}
                alt={target.name}
                title="Click to enlarge"
              />

              <p id="imageLabel" class="image-label">
                {firstImage.label}
              </p>

              {target.annotatedImage && (
                <div class="view-toggle">
                  <button id="originalViewBtn" class="active" type="button">
                    Original
                  </button>
                  <button id="annotatedViewBtn" type="button">
                    Annotated
                  </button>
                </div>
              )}

              {target.images.length > 1 && (
                <>
                  <div class="controls">
                    <button id="prevBtn" type="button">←</button>
                    <span id="counter">1 / {target.images.length}</span>
                    <button id="nextBtn" type="button">→</button>
                  </div>

                  <div class="thumbnails">
                    {target.images.map((img, i) => (
                      <img
                        src={img.url}
                        alt={img.label}
                        class={`thumb ${i === 0 ? "active" : ""}`}
                        data-index={i}
                      />
                    ))}
                  </div>
                </>
              )}
            </>
          ) : (
            <div class="missing-image">
              No photos found in this Cloudflare folder yet.
            </div>
          )}
        </div>

        <div class="content">
          <p class="category">{target.category}</p>

          <h1>
            {target.catalog ? `${target.catalog}: ${target.name}` : target.name}
          </h1>

          <p class="description">{target.description}</p>

          <section class="info-grid">
            {target.dateCaptured && (
              <div class="info-card">
                <span>Date captured</span>
                <strong>{target.dateCaptured}</strong>
              </div>
            )}

            {target.equipment && (
              <div class="info-card">
                <span>Equipment</span>
                <strong>{target.equipment}</strong>
              </div>
            )}

            {target.location && (
              <div class="info-card">
                <span>Location</span>
                <strong>{target.location}</strong>
              </div>
            )}

            {target.observationSummary?.sessions > 0 && (
              <div class="info-card">
                <span>Total integration</span>
                <strong>{target.observationSummary.totalHours} hours</strong>
              </div>
            )}
          </section>

          {quickFacts.length > 0 && (
            <section class="extra">
              <h2>Quick Facts</h2>
              <div class="facts-grid">
                {quickFacts.map(([label, value]) => (
                  <div class="fact-card">
                    <span>{label}</span>
                    <strong>{value}</strong>
                  </div>
                ))}
              </div>
            </section>
          )}

          {target.skyMap && (
            <section class="extra">
              <h2>Where it is in the sky</h2>
              <p>
                This simple finder map shows the general area of the night sky
                where this target is located.
              </p>

              <a href={target.skyMap.url} target="_blank" rel="noopener noreferrer">
                <img
                  class="sky-map"
                  src={target.skyMap.url}
                  alt={`${target.name} sky map`}
                />
              </a>
            </section>
          )}

          {target.whatYouAreSeeing && (
            <section class="extra">
              <h2>What you're looking at</h2>
              <p>{target.whatYouAreSeeing}</p>
            </section>
          )}

          {target.whyItIsInteresting && (
            <section class="extra">
              <h2>Why it is interesting</h2>
              <p>{target.whyItIsInteresting}</p>
            </section>
          )}

          {target.captureNotes && (
            <section class="extra">
              <h2>How I captured it</h2>
              <p>{target.captureNotes}</p>
            </section>
          )}

          {target.observationSummary?.sessions > 0 && (
            <section class="extra">
              <h2>Observation Log</h2>
              <p>
                Total integration time:
                <strong>{target.observationSummary.totalHours} hours</strong>
                across {target.observationSummary.sessions} sessions.
              </p>

              <div class="download-list">
                {target.observations.map((item) => (
                  <div class="download-card">
                    <div>
                      <strong>{item.date} — {item.minutes} minutes</strong>
                      <span>{item.subSeconds} second exposures</span>
                      {item.notes && <p>{item.notes}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          {target.downloads?.length > 0 && (
            <section class="downloads">
              <h2>Download raw files</h2>
              <p>
                Want to try processing this target yourself? Download the
                original data files below.
              </p>

              <div class="download-list">
                {target.downloads.map((file) => (
                  <a class="download-card" href={file.url} download>
                    <div>
                      <strong>{file.label}</strong>
                      <span>{file.type} file</span>
                    </div>
                    <span class="download-button">Download</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </article>
    </main>

    {target.images?.length > 0 && firstImage && (
      <div id="lightbox" class="lightbox" aria-hidden="true">
        <button
          id="lightboxClose"
          class="lightbox-close"
          type="button"
          aria-label="Close full screen image"
        >
          ×
        </button>

        <div class="zoom-controls">
          <button id="zoomOutBtn" type="button" aria-label="Zoom out">−</button>
          <button id="zoomResetBtn" type="button" aria-label="Reset zoom">Reset</button>
          <button id="zoomInBtn" type="button" aria-label="Zoom in">+</button>
        </div>

        {target.images.length > 1 && (
          <button
            id="lightboxPrev"
            class="lightbox-nav lightbox-prev"
            type="button"
            aria-label="Previous image"
          >
            ←
          </button>
        )}

        <div class="lightbox-image-wrap">
          <img id="lightboxImage" src={firstImage.url} alt={firstImage.label} />
        </div>

        {target.images.length > 1 && (
          <button
            id="lightboxNext"
            class="lightbox-nav lightbox-next"
            type="button"
            aria-label="Next image"
          >
            →
          </button>
        )}

        <p id="lightboxLabel" class="lightbox-label">{firstImage.label}</p>

        <a
          id="fullResolutionLink"
          class="full-resolution-link"
          href={firstImage.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          View full resolution
        </a>
      </div>
    )}

    {target.images?.length > 0 && (
      <script define:vars={{ images: target.images, annotatedImage: target.annotatedImage }}>
        let currentIndex = 0;
        let zoomLevel = 1;
        let showingAnnotated = false;

        const mainImage = document.getElementById("mainImage");
        const imageLabel = document.getElementById("imageLabel");
        const counter = document.getElementById("counter");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const thumbs = document.querySelectorAll(".thumb");

        const originalViewBtn = document.getElementById("originalViewBtn");
        const annotatedViewBtn = document.getElementById("annotatedViewBtn");

        const lightbox = document.getElementById("lightbox");
        const lightboxImage = document.getElementById("lightboxImage");
        const lightboxLabel = document.getElementById("lightboxLabel");
        const lightboxClose = document.getElementById("lightboxClose");
        const lightboxPrev = document.getElementById("lightboxPrev");
        const lightboxNext = document.getElementById("lightboxNext");
        const fullResolutionLink = document.getElementById("fullResolutionLink");

        const zoomInBtn = document.getElementById("zoomInBtn");
        const zoomOutBtn = document.getElementById("zoomOutBtn");
        const zoomResetBtn = document.getElementById("zoomResetBtn");

        function getCurrentDisplayImage() {
          return showingAnnotated && annotatedImage
            ? annotatedImage
            : images[currentIndex];
        }

        function updateToggleButtons() {
          if (!originalViewBtn || !annotatedViewBtn) return;

          originalViewBtn.classList.toggle("active", !showingAnnotated);
          annotatedViewBtn.classList.toggle("active", showingAnnotated);
        }

        function updateZoom() {
          if (!lightboxImage) return;

          lightboxImage.style.transform = `scale(${zoomLevel})`;
          lightboxImage.style.cursor = zoomLevel > 1 ? "zoom-out" : "zoom-in";
        }

        function zoomIn() {
          zoomLevel = Math.min(zoomLevel + 0.25, 4);
          updateZoom();
        }

        function zoomOut() {
          zoomLevel = Math.max(zoomLevel - 0.25, 1);
          updateZoom();
        }

        function resetZoom() {
          zoomLevel = 1;
          updateZoom();
        }

        function updateActiveThumb() {
          thumbs.forEach((thumb) => thumb.classList.remove("active"));

          if (!showingAnnotated && thumbs[currentIndex]) {
            thumbs[currentIndex].classList.add("active");
          }
        }

        function updateDisplayedImage() {
          const img = getCurrentDisplayImage();

          if (mainImage) {
            mainImage.src = img.url;
            mainImage.alt = img.label;
          }

          if (imageLabel) {
            imageLabel.textContent = img.label;
          }

          if (counter && !showingAnnotated) {
            counter.textContent = `${currentIndex + 1} / ${images.length}`;
          }

          if (counter && showingAnnotated) {
            counter.textContent = "Annotated";
          }

          if (lightboxImage) {
            lightboxImage.src = img.url;
            lightboxImage.alt = img.label;
          }

          if (lightboxLabel) {
            lightboxLabel.textContent = img.label;
          }

          if (fullResolutionLink) {
            fullResolutionLink.href = img.url;
          }

          updateActiveThumb();
          updateToggleButtons();
        }

        function showImage(index) {
          currentIndex = index;
          showingAnnotated = false;
          resetZoom();
          updateDisplayedImage();
        }

        function showAnnotated() {
          if (!annotatedImage) return;
          showingAnnotated = true;
          resetZoom();
          updateDisplayedImage();
        }

        function showOriginal() {
          showingAnnotated = false;
          resetZoom();
          updateDisplayedImage();
        }

        function openLightbox() {
          if (!lightbox) return;

          resetZoom();
          lightbox.classList.add("open");
          lightbox.setAttribute("aria-hidden", "false");
          document.body.classList.add("lightbox-open");
        }

        function closeLightbox() {
          if (!lightbox) return;

          resetZoom();
          lightbox.classList.remove("open");
          lightbox.setAttribute("aria-hidden", "true");
          document.body.classList.remove("lightbox-open");
        }

        if (mainImage) {
          mainImage.addEventListener("click", openLightbox);
        }

        if (originalViewBtn) {
          originalViewBtn.addEventListener("click", showOriginal);
        }

        if (annotatedViewBtn) {
          annotatedViewBtn.addEventListener("click", showAnnotated);
        }

        if (lightboxImage) {
          lightboxImage.addEventListener("click", () => {
            if (zoomLevel === 1) {
              zoomIn();
            } else {
              resetZoom();
            }
          });
        }

        if (zoomInBtn) {
          zoomInBtn.addEventListener("click", (event) => {
            event.stopPropagation();
            zoomIn();
          });
        }

        if (zoomOutBtn) {
          zoomOutBtn.addEventListener("click", (event) => {
            event.stopPropagation();
            zoomOut();
          });
        }

        if (zoomResetBtn) {
          zoomResetBtn.addEventListener("click", (event) => {
            event.stopPropagation();
            resetZoom();
          });
        }

        if (lightboxClose) {
          lightboxClose.addEventListener("click", closeLightbox);
        }

        if (lightbox) {
          lightbox.addEventListener("click", (event) => {
            if (event.target === lightbox) {
              closeLightbox();
            }
          });
        }

        if (lightboxPrev) {
          lightboxPrev.addEventListener("click", (event) => {
            event.stopPropagation();
            showImage((currentIndex - 1 + images.length) % images.length);
          });
        }

        if (lightboxNext) {
          lightboxNext.addEventListener("click", (event) => {
            event.stopPropagation();
            showImage((currentIndex + 1) % images.length);
          });
        }

        thumbs.forEach((thumb) => {
          thumb.addEventListener("click", () => {
            showImage(Number(thumb.dataset.index));
          });
        });

        if (prevBtn && nextBtn) {
          prevBtn.addEventListener("click", () => {
            showImage((currentIndex - 1 + images.length) % images.length);
          });

          nextBtn.addEventListener("click", () => {
            showImage((currentIndex + 1) % images.length);
          });
        }

        document.addEventListener("keydown", (event) => {
          const isOpen = lightbox?.classList.contains("open");

          if (event.key === "Escape") {
            closeLightbox();
          }

          if (event.key === "ArrowLeft") {
            showImage((currentIndex - 1 + images.length) % images.length);
          }

          if (event.key === "ArrowRight") {
            showImage((currentIndex + 1) % images.length);
          }

          if (isOpen && (event.key === "+" || event.key === "=")) {
            zoomIn();
          }

          if (isOpen && event.key === "-") {
            zoomOut();
          }

          if (isOpen && event.key === "0") {
            resetZoom();
          }
        });

        updateActiveThumb();
        updateToggleButtons();
        updateZoom();
      </script>
    )}
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #0c1222, #05070d);
    color: white;
  }

  body.lightbox-open {
    overflow: hidden;
  }

  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 32px 20px 48px;
  }

  .back {
    color: #9db7ff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 24px;
  }

  .target {
    background: rgba(18, 24, 39, 0.75);
    border: 1px solid rgba(125, 162, 255, 0.22);
    border-radius: 22px;
    overflow: hidden;
  }

  .image-panel {
    background: black;
  }

  #mainImage {
    width: 100%;
    max-height: 650px;
    object-fit: contain;
    display: block;
    cursor: zoom-in;
    background: black;
  }

  .missing-image {
    min-height: 260px;
    display: grid;
    place-items: center;
    color: #9db7ff;
    padding: 24px;
    text-align: center;
  }

  .image-label {
    text-align: center;
    font-size: 14px;
    color: #c7d2ea;
    margin: 0;
    padding: 10px 12px 12px;
    background: #05070d;
  }

  .view-toggle {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    background: #05070d;
  }

  .view-toggle button {
    background: #121827;
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    padding: 8px 14px;
    border-radius: 999px;
    cursor: pointer;
  }

  .view-toggle button.active {
    background: #26335f;
    border-color: #7da2ff;
  }

  .controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background: #05070d;
  }

  .controls button {
    background: #121827;
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    padding: 9px 14px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 18px;
  }

  #counter {
    color: #c7d2ea;
    font-size: 14px;
    min-width: 80px;
    text-align: center;
  }

  .thumbnails {
    display: flex;
    gap: 8px;
    padding: 12px;
    overflow-x: auto;
    background: #05070d;
  }

  .thumb {
    height: 64px;
    width: 88px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    opacity: 0.65;
    border: 2px solid transparent;
    flex: 0 0 auto;
    background: black;
  }

  .thumb:hover {
    opacity: 1;
  }

  .thumb.active {
    border-color: #7da2ff;
    opacity: 1;
  }

  .content {
    padding: 26px;
  }

  .category {
    color: #9db7ff;
    font-size: 14px;
    margin: 0 0 10px;
  }

  h1 {
    font-size: 38px;
    margin: 0 0 18px;
  }

  .description {
    color: #d8deee;
    font-size: 18px;
    line-height: 1.65;
    margin-bottom: 26px;
  }

  .info-grid,
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 28px;
  }

  .info-card,
  .fact-card {
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
  }

  .info-card span,
  .fact-card span {
    display: block;
    color: #9db7ff;
    font-size: 13px;
    margin-bottom: 6px;
  }

  .info-card strong,
  .fact-card strong {
    color: white;
    font-size: 15px;
  }

  .extra,
  .downloads {
    border-top: 1px solid rgba(125, 162, 255, 0.2);
    padding-top: 22px;
    margin-top: 22px;
  }

  .extra h2,
  .downloads h2 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .extra p,
  .downloads p {
    color: #c7d2ea;
    line-height: 1.6;
  }

  .sky-map {
    width: 100%;
    max-height: 520px;
    object-fit: contain;
    background: black;
    border-radius: 14px;
    border: 1px solid rgba(125, 162, 255, 0.22);
    margin-top: 12px;
  }

  .download-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .download-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    background: rgba(5, 7, 13, 0.55);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
    color: white;
    text-decoration: none;
  }

  .download-card strong {
    display: block;
    margin-bottom: 4px;
  }

  .download-card span {
    color: #9db7ff;
    font-size: 14px;
  }

  .download-button {
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    padding: 8px 12px;
    white-space: nowrap;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.92);
    padding: 24px;
  }

  .lightbox.open {
    display: flex;
  }

  .lightbox-image-wrap {
    max-width: 96vw;
    max-height: 78vh;
    overflow: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox img {
    max-width: 96vw;
    max-height: 78vh;
    object-fit: contain;
    border-radius: 10px;
    transition: transform 0.15s ease;
    transform-origin: center center;
  }

  .lightbox-label {
    color: #c7d2ea;
    font-size: 14px;
    margin: 12px 0 0;
    text-align: center;
  }

  .full-resolution-link {
    color: white;
    text-decoration: none;
    margin-top: 12px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    padding: 8px 14px;
    background: rgba(18, 24, 39, 0.9);
    font-size: 14px;
  }

  .full-resolution-link:hover {
    background: #1c2540;
  }

  .lightbox-close {
    position: fixed;
    top: 18px;
    right: 22px;
    background: rgba(18, 24, 39, 0.9);
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    width: 42px;
    height: 42px;
    cursor: pointer;
    font-size: 28px;
    line-height: 1;
  }

  .zoom-controls {
    position: fixed;
    top: 18px;
    left: 22px;
    display: flex;
    gap: 8px;
    z-index: 10000;
  }

  .zoom-controls button {
    background: rgba(18, 24, 39, 0.9);
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 14px;
  }

  .zoom-controls button:hover {
    background: #1c2540;
  }

  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(18, 24, 39, 0.9);
    color: white;
    border: 1px solid rgba(125, 162, 255, 0.35);
    border-radius: 999px;
    width: 48px;
    height: 48px;
    cursor: pointer;
    font-size: 28px;
    line-height: 1;
  }

  .lightbox-prev {
    left: 24px;
  }

  .lightbox-next {
    right: 24px;
  }

  .lightbox-nav:hover,
  .lightbox-close:hover {
    background: #1c2540;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }

    .lightbox-nav {
      width: 42px;
      height: 42px;
      font-size: 24px;
    }

    .lightbox-prev {
      left: 10px;
    }

    .lightbox-next {
      right: 10px;
    }

    .zoom-controls {
      left: 10px;
      top: 12px;
    }

    .zoom-controls button {
      padding: 7px 10px;
      font-size: 13px;
    }
  }
</style>