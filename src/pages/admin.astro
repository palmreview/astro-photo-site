---
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Admin | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a href="/">← Back to gallery</a>
      <h1>Photo Admin</h1>

      <section class="panel status-panel">
        <div class="panel-header">
          <h2>Site Status</h2>
          <button id="refreshStatusBtn" type="button">Refresh Status</button>
        </div>

        <div id="statusGrid" class="status-grid">
          <p class="muted">Enter your admin token and refresh status.</p>
        </div>
      </section>

      <section class="panel">
        <h2>Target Selector</h2>
        <p class="muted">
          Pick an existing target so you do not have to type the folder every time.
          You can still create/use a brand-new folder below.
        </p>

        <label>
          Admin token
          <input id="token" type="password" placeholder="Admin token" />
        </label>

        <div class="form-grid">
          <label>
            Existing target
            <select id="targetSelect">
              <option value="">Load targets first...</option>
            </select>
          </label>

          <label>
            New target folder
            <input id="newFolder" type="text" placeholder="deep-sky/M 27" />
          </label>
        </div>

        <div class="button-row">
          <button id="loadTargetsBtn" type="button">Load Targets</button>
          <button id="useSelectedTargetBtn" type="button">Use Selected Target</button>
          <button id="useNewFolderBtn" type="button">Use New Folder</button>
        </div>

        <p class="selected-folder">
          Current folder:
          <code id="selectedFolderLabel">None selected</code>
        </p>
      </section>

      <section class="panel">
        <h2>Upload photo</h2>

        <label>
          R2 folder
          <input id="folder" type="text" placeholder="deep-sky/M 81" />
        </label>

        <label>
          File name
          <input id="filename" type="text" placeholder="main.jpg" />
        </label>

        <label>
          Photo
          <input id="file" type="file" accept="image/*" />
        </label>

        <img id="preview" class="preview" alt="Upload preview" />

        <div class="button-row">
          <button id="uploadBtn" type="button">Upload</button>
          <button id="uploadSkyMapBtn" type="button">Upload Sky Map</button>
          <button id="uploadAnnotatedBtn" type="button">Upload Annotated Image</button>
          <button id="listBtn" type="button">List files in folder</button>
          <button id="loadInfoBtn" type="button">Load Target Info</button>
          <button id="loadObservationsBtn" type="button">Load Observations</button>
          <button id="redeployBtn" type="button">Redeploy Site</button>
        </div>

        <p class="muted">
          Sky Map saves as <code>sky-map.jpg</code>. Annotated Image saves as <code>annotated.jpg</code>.
        </p>
      </section>

      <section class="panel">
        <h2>Files in folder</h2>
        <p class="muted">
          Use <strong>Make Main</strong> to choose which image appears first.
          Use <strong>Rename</strong> to change a file name inside this folder.
        </p>

        <div id="fileList" class="file-list">
          <p class="muted">Choose a folder and click “List files in folder.”</p>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2>Hidden / Trash Files</h2>
          <button id="listHiddenBtn" type="button">List Hidden Files</button>
        </div>

        <p class="muted">
          Restore files you hid, or permanently delete them when you are sure.
        </p>

        <div id="hiddenList" class="file-list">
          <p class="muted">Click “List Hidden Files” to view hidden files.</p>
        </div>
      </section>

      <section class="panel">
        <h2>Observation Log</h2>
        <p class="muted">Track each imaging session for the selected folder.</p>

        <div class="form-grid">
          <label>
            Date
            <input id="obsDate" type="date" />
          </label>

          <label>
            Total Minutes
            <input id="obsMinutes" type="number" placeholder="90" />
          </label>

          <label>
            Sub Exposure Seconds
            <input id="obsSubSeconds" type="number" placeholder="20" />
          </label>
        </div>

        <label>
          Notes
          <textarea id="obsNotes" rows="3" placeholder="Clear night, added more M81 data, some clouds..."></textarea>
        </label>

        <div class="button-row">
          <button id="addObservationBtn" type="button">Add Observation</button>
        </div>

        <div id="observationList" class="file-list">
          <p class="muted">Load observations for this folder.</p>
        </div>
      </section>

      <section class="panel">
        <h2>Target Info Editor</h2>
        <p class="muted">
          This saves an <code>info.json</code> file inside the selected R2 folder.
        </p>

        <div class="button-row info-actions">
          <button id="generateInfoBtn" type="button">Generate Starter Info</button>
          <button id="saveInfoBtn" type="button">Save Target Info</button>
        </div>

        <div class="form-grid">
          <label>Name <input id="infoName" type="text" /></label>
          <label>Catalog <input id="infoCatalog" type="text" /></label>
          <label>Category <input id="infoCategory" type="text" /></label>
          <label>Object Type <input id="infoObjectType" type="text" /></label>
          <label>Constellation <input id="infoConstellation" type="text" /></label>
          <label>Distance <input id="infoDistance" type="text" /></label>
          <label>Apparent Magnitude <input id="infoApparentMagnitude" type="text" /></label>
          <label>Diameter <input id="infoDiameter" type="text" /></label>
          <label>Discovered <input id="infoDiscovered" type="text" /></label>
          <label>Date Captured <input id="infoDateCaptured" type="text" /></label>
          <label>Equipment <input id="infoEquipment" type="text" /></label>
          <label>Location <input id="infoLocation" type="text" /></label>
        </div>

        <label>Short Description <textarea id="infoShortDescription" rows="2"></textarea></label>
        <label>Description <textarea id="infoDescription" rows="4"></textarea></label>
        <label>What you're looking at <textarea id="infoWhatYouAreSeeing" rows="4"></textarea></label>
        <label>Why it is interesting <textarea id="infoWhyItIsInteresting" rows="4"></textarea></label>
        <label>Capture Notes <textarea id="infoCaptureNotes" rows="4"></textarea></label>
      </section>

      <pre id="result">Ready.</pre>
    </main>

    <script define:vars={{ adminApiUrl }}>
      const result = document.getElementById("result");
      const statusGrid = document.getElementById("statusGrid");
      const fileList = document.getElementById("fileList");
      const hiddenList = document.getElementById("hiddenList");
      const observationList = document.getElementById("observationList");

      const tokenInput = document.getElementById("token");
      const folderInput = document.getElementById("folder");
      const newFolderInput = document.getElementById("newFolder");
      const targetSelect = document.getElementById("targetSelect");
      const selectedFolderLabel = document.getElementById("selectedFolderLabel");

      const loadTargetsBtn = document.getElementById("loadTargetsBtn");
      const useSelectedTargetBtn = document.getElementById("useSelectedTargetBtn");
      const useNewFolderBtn = document.getElementById("useNewFolderBtn");

      const uploadBtn = document.getElementById("uploadBtn");
      const uploadSkyMapBtn = document.getElementById("uploadSkyMapBtn");
      const uploadAnnotatedBtn = document.getElementById("uploadAnnotatedBtn");
      const listBtn = document.getElementById("listBtn");
      const listHiddenBtn = document.getElementById("listHiddenBtn");
      const loadInfoBtn = document.getElementById("loadInfoBtn");
      const saveInfoBtn = document.getElementById("saveInfoBtn");
      const generateInfoBtn = document.getElementById("generateInfoBtn");
      const redeployBtn = document.getElementById("redeployBtn");
      const refreshStatusBtn = document.getElementById("refreshStatusBtn");
      const addObservationBtn = document.getElementById("addObservationBtn");
      const loadObservationsBtn = document.getElementById("loadObservationsBtn");

      const fileInput = document.getElementById("file");
      const preview = document.getElementById("preview");

      const STORAGE_KEY = "astroAdminSelectedFolder";

      const infoFields = {
        name: document.getElementById("infoName"),
        catalog: document.getElementById("infoCatalog"),
        category: document.getElementById("infoCategory"),
        objectType: document.getElementById("infoObjectType"),
        constellation: document.getElementById("infoConstellation"),
        distance: document.getElementById("infoDistance"),
        apparentMagnitude: document.getElementById("infoApparentMagnitude"),
        diameter: document.getElementById("infoDiameter"),
        discovered: document.getElementById("infoDiscovered"),
        dateCaptured: document.getElementById("infoDateCaptured"),
        equipment: document.getElementById("infoEquipment"),
        location: document.getElementById("infoLocation"),
        shortDescription: document.getElementById("infoShortDescription"),
        description: document.getElementById("infoDescription"),
        whatYouAreSeeing: document.getElementById("infoWhatYouAreSeeing"),
        whyItIsInteresting: document.getElementById("infoWhyItIsInteresting"),
        captureNotes: document.getElementById("infoCaptureNotes")
      };

      function show(message) {
        result.textContent =
          typeof message === "string" ? message : JSON.stringify(message, null, 2);
      }

      function getToken() {
        return tokenInput.value.trim();
      }

      function getFolder() {
        return folderInput.value.trim().replace(/\/$/, "");
      }

      function setFolder(folder) {
        const cleaned = folder.trim().replace(/\/$/, "");
        folderInput.value = cleaned;
        selectedFolderLabel.textContent = cleaned || "None selected";

        if (cleaned) {
          localStorage.setItem(STORAGE_KEY, cleaned);
        }

        [...targetSelect.options].forEach((option) => {
          option.selected = option.value === cleaned;
        });
      }

      function requireBasics({ requireFolder = true } = {}) {
        if (!adminApiUrl) {
          show("Missing PUBLIC_ADMIN_API_URL.");
          return false;
        }

        if (!getToken()) {
          show("Please enter your admin token.");
          return false;
        }

        if (requireFolder && !getFolder()) {
          show("Please select or enter a folder.");
          return false;
        }

        return true;
      }

      async function readResponse(response) {
        const text = await response.text();

        try {
          return JSON.parse(text);
        } catch {
          return {
            ok: response.ok,
            status: response.status,
            responseText: text || "No response body"
          };
        }
      }

      async function api(path, options = {}) {
        const response = await fetch(`${adminApiUrl}${path}`, {
          ...options,
          headers: {
            Authorization: `Bearer ${getToken()}`,
            ...(options.headers || {})
          }
        });

        const data = await readResponse(response);

        if (!response.ok) throw { response, data };

        return data;
      }

      function formatDate(value) {
        if (!value) return "Never";
        try {
          return new Date(value).toLocaleString();
        } catch {
          return value;
        }
      }

      function fillInfoFields(info) {
        Object.entries(infoFields).forEach(([key, element]) => {
          element.value = info?.[key] || "";
        });
      }

      function collectInfoFields() {
        const info = {};
        Object.entries(infoFields).forEach(([key, element]) => {
          info[key] = element.value.trim();
        });
        return info;
      }

      async function loadTargets() {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          loadTargetsBtn.disabled = true;
          show("Loading target folders...");

          const data = await api("/targets");
          const folders = data.folders || [];

          targetSelect.innerHTML = "";

          if (!folders.length) {
            targetSelect.innerHTML = `<option value="">No targets found</option>`;
          } else {
            targetSelect.innerHTML = `<option value="">Select target...</option>` +
              folders.map((folder) => `<option value="${folder}">${folder}</option>`).join("");
          }

          const saved = localStorage.getItem(STORAGE_KEY);
          if (saved && folders.includes(saved)) {
            setFolder(saved);
          }

          show(data);
        } catch (error) {
          show({ ok: false, message: "Load targets failed", details: error.data || error.message });
        } finally {
          loadTargetsBtn.disabled = false;
        }
      }

      function useSelectedTarget() {
        const folder = targetSelect.value;
        if (!folder) {
          show("Please select a target first.");
          return;
        }

        setFolder(folder);
        show(`Selected folder: ${folder}`);
      }

      function useNewFolder() {
        const folder = newFolderInput.value.trim().replace(/\/$/, "");

        if (!folder) {
          show("Please enter a new folder, like deep-sky/M 27.");
          return;
        }

        setFolder(folder);
        show({
          ok: true,
          action: "new_folder_selected",
          folder,
          note: "Now upload an image or save info to create files in this folder."
        });
      }

      function renderStatus(status) {
        statusGrid.innerHTML = `
          <div class="status-card"><span>Last redeploy requested</span><strong>${formatDate(status.lastRedeployRequestedAt)}</strong></div>
          <div class="status-card"><span>Last redeploy status</span><strong>${status.lastRedeployStatus || "Unknown"}</strong></div>
          <div class="status-card"><span>Last upload</span><strong>${formatDate(status.lastUploadAt)}</strong><code>${status.lastUploadKey || ""}</code></div>
          <div class="status-card"><span>Last main image</span><strong>${formatDate(status.lastMainImageAt)}</strong><code>${status.lastMainImageKey || ""}</code></div>
          <div class="status-card"><span>Last rename</span><strong>${formatDate(status.lastRenameAt)}</strong><code>${status.lastRenameTo || ""}</code></div>
          <div class="status-card"><span>Last hidden file</span><strong>${formatDate(status.lastHideAt)}</strong><code>${status.lastHideKey || ""}</code></div>
          <div class="status-card"><span>Last restore</span><strong>${formatDate(status.lastRestoreAt)}</strong><code>${status.lastRestoreKey || ""}</code></div>
          <div class="status-card"><span>Last delete</span><strong>${formatDate(status.lastDeleteAt)}</strong><code>${status.lastDeleteKey || ""}</code></div>
          <div class="status-card"><span>Last info save</span><strong>${formatDate(status.lastInfoSaveAt)}</strong><code>${status.lastInfoFolder || ""}</code></div>
          <div class="status-card"><span>Last observation</span><strong>${formatDate(status.lastObservationAt)}</strong><code>${status.lastObservationFolder || ""}</code></div>
        `;
      }

      async function refreshStatus() {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          refreshStatusBtn.disabled = true;
          const data = await api("/status");
          renderStatus(data.status || {});
          show(data);
        } catch (error) {
          show({ ok: false, message: "Status failed", details: error.data || error.message });
        } finally {
          refreshStatusBtn.disabled = false;
        }
      }

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];

        if (!file) {
          preview.style.display = "none";
          preview.src = "";
          return;
        }

        preview.src = URL.createObjectURL(file);
        preview.style.display = "block";
      });

      async function uploadFileToKey(key, button) {
        const file = fileInput.files[0];

        if (!file) {
          show("Please choose a file first.");
          return;
        }

        try {
          button.disabled = true;
          show(`Uploading ${key}...`);

          const response = await fetch(`${adminApiUrl}/upload?key=${encodeURIComponent(key)}`, {
            method: "PUT",
            headers: {
              Authorization: `Bearer ${getToken()}`,
              "Content-Type": file.type || "application/octet-stream"
            },
            body: file
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({ ok: false, message: "Upload failed", details: data });
            return;
          }

          show({
            ...data,
            note: "Upload complete. Click Redeploy Site for the public site to update."
          });

          await listFiles();
          await refreshStatus();
          await loadTargets();
        } catch (error) {
          show(`Upload failed: ${error.message}`);
        } finally {
          button.disabled = false;
        }
      }

      uploadBtn.addEventListener("click", async () => {
        if (!requireBasics()) return;

        const folder = getFolder();
        const filename = document.getElementById("filename").value.trim();

        if (!filename) {
          show("Please enter a filename.");
          return;
        }

        await uploadFileToKey(`${folder}/${filename}`, uploadBtn);
      });

      uploadSkyMapBtn.addEventListener("click", async () => {
        if (!requireBasics()) return;

        const folder = getFolder();

        if (!confirm(`Upload selected image as sky-map.jpg?\n\n${folder}/sky-map.jpg`)) {
          return;
        }

        await uploadFileToKey(`${folder}/sky-map.jpg`, uploadSkyMapBtn);
      });

      uploadAnnotatedBtn.addEventListener("click", async () => {
        if (!requireBasics()) return;

        const folder = getFolder();

        if (!confirm(`Upload selected image as annotated.jpg?\n\n${folder}/annotated.jpg`)) {
          return;
        }

        await uploadFileToKey(`${folder}/annotated.jpg`, uploadAnnotatedBtn);
      });

      async function listFiles() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          listBtn.disabled = true;
          show(`Listing files in ${folder}...`);

          const data = await api(`/list?folder=${encodeURIComponent(folder)}`);
          renderFileList(data.files || []);
          show(data);
        } catch (error) {
          show({ ok: false, message: "List failed", details: error.data || error.message });
        } finally {
          listBtn.disabled = false;
        }
      }

      function renderFileList(files) {
        if (!files.length) {
          fileList.innerHTML = `<p class="muted">No image files found in this folder.</p>`;
          return;
        }

        fileList.innerHTML = files.map((file) => `
          <div class="file-card ${file.isMain ? "main-file" : ""} ${file.isSkyMap ? "sky-map-file" : ""} ${file.filename === "annotated.jpg" ? "annotated-file" : ""}">
            <img src="${file.url}" alt="${file.filename}" />
            <div class="file-info">
              <strong>
                ${file.filename}
                ${file.isMain ? "⭐ Main" : ""}
                ${file.isSkyMap ? "🗺️ Sky Map" : ""}
                ${file.filename === "annotated.jpg" ? "🏷️ Annotated" : ""}
              </strong>
              <code>${file.key}</code>
              <a href="${file.url}" target="_blank" rel="noopener noreferrer">View full image</a>
            </div>
            <div class="file-actions">
              <button class="make-main-btn" data-key="${file.key}" type="button">Make Main</button>
              <button class="rename-file-btn" data-key="${file.key}" data-filename="${file.filename}" type="button">Rename</button>
              <button class="hide-file-btn" data-key="${file.key}" type="button">Hide</button>
            </div>
          </div>
        `).join("");

        document.querySelectorAll(".make-main-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await makeMainFile(button.dataset.key);
            await listFiles();
            await refreshStatus();
          });
        });

        document.querySelectorAll(".rename-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await renameFile(button.dataset.key, button.dataset.filename);
            await listFiles();
            await refreshStatus();
          });
        });

        document.querySelectorAll(".hide-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await hideFile(button.dataset.key);
            await listFiles();
            await refreshStatus();
          });
        });
      }

      async function makeMainFile(key) {
        if (!confirm(`Make this the main image?\n\n${key}`)) return;

        try {
          const data = await api("/make-main", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ key })
          });

          show({ ...data, note: "Click Redeploy Site for the public site to update." });
        } catch (error) {
          show({ ok: false, message: "Make main failed", details: error.data || error.message });
        }
      }

      async function renameFile(oldKey, currentFilename) {
        const newFilename = prompt("Enter new filename:", currentFilename);
        if (!newFilename) return;

        try {
          const data = await api("/rename", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ oldKey, newFilename })
          });

          show({
            ...data,
            note: "File renamed successfully. Click Redeploy Site for the public site to update."
          });
        } catch (error) {
          show({ ok: false, message: "Rename failed", details: error.data || error.message });
        }
      }

      async function hideFile(key) {
        if (!confirm(`Hide this file?\n\n${key}`)) return;

        try {
          const data = await api("/hide", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ key })
          });

          show(data);
        } catch (error) {
          show({ ok: false, message: "Hide failed", details: error.data || error.message });
        }
      }

      async function listHiddenFiles() {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          listHiddenBtn.disabled = true;
          const data = await api("/hidden");
          renderHiddenList(data.files || []);
          show(data);
        } catch (error) {
          show({ ok: false, message: "Hidden list failed", details: error.data || error.message });
        } finally {
          listHiddenBtn.disabled = false;
        }
      }

      function renderHiddenList(files) {
        if (!files.length) {
          hiddenList.innerHTML = `<p class="muted">No hidden files found.</p>`;
          return;
        }

        hiddenList.innerHTML = files.map((file) => `
          <div class="file-card hidden-file">
            <img src="${file.url}" alt="${file.filename}" />
            <div class="file-info">
              <strong>${file.filename}</strong>
              <code>${file.hiddenKey}</code>
              <small>Restore to: ${file.originalKey}</small>
              <a href="${file.url}" target="_blank" rel="noopener noreferrer">View hidden image</a>
            </div>
            <div class="file-actions">
              <button class="restore-file-btn" data-key="${file.hiddenKey}" type="button">Restore</button>
              <button class="delete-file-btn" data-key="${file.hiddenKey}" type="button">Delete Forever</button>
            </div>
          </div>
        `).join("");

        document.querySelectorAll(".restore-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await restoreHiddenFile(button.dataset.key);
            await listHiddenFiles();
            await refreshStatus();
          });
        });

        document.querySelectorAll(".delete-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await deleteHiddenFile(button.dataset.key);
            await listHiddenFiles();
            await refreshStatus();
          });
        });
      }

      async function restoreHiddenFile(hiddenKey) {
        if (!confirm(`Restore this file?\n\n${hiddenKey}`)) return;

        try {
          const data = await api("/restore", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ hiddenKey })
          });

          show({ ...data, note: "Click Redeploy Site for the public site to update." });
        } catch (error) {
          show({ ok: false, message: "Restore failed", details: error.data || error.message });
        }
      }

      async function deleteHiddenFile(hiddenKey) {
        if (!confirm(`Permanently delete this hidden file?\n\n${hiddenKey}\n\nThis cannot be undone.`)) return;

        try {
          const data = await api("/delete-hidden", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ hiddenKey })
          });

          show(data);
        } catch (error) {
          show({ ok: false, message: "Delete failed", details: error.data || error.message });
        }
      }

      async function loadObservations() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          const data = await api(`/observations?folder=${encodeURIComponent(folder)}`);
          renderObservations(data);
          show(data);
        } catch (error) {
          show({ ok: false, message: "Load observations failed", details: error.data || error.message });
        }
      }

      function renderObservations(data) {
        const observations = data.observations || [];
        const summary = data.summary || {};

        if (!observations.length) {
          observationList.innerHTML = `<p class="muted">No observations logged yet.</p>`;
          return;
        }

        observationList.innerHTML = `
          <div class="status-card">
            <span>Total Integration</span>
            <strong>${summary.totalHours} hours</strong>
            <code>${summary.totalMinutes} minutes across ${summary.sessions} sessions</code>
          </div>

          ${observations.map((item) => `
            <div class="file-card">
              <div class="file-info">
                <strong>${item.date} — ${item.minutes} min</strong>
                <code>${item.subSeconds || "?"} sec subs</code>
                <small>${item.notes || ""}</small>
              </div>
              <div class="file-actions">
                <button class="delete-observation-btn" data-id="${item.id}" type="button">Delete</button>
              </div>
            </div>
          `).join("")}
        `;

        document.querySelectorAll(".delete-observation-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await deleteObservation(button.dataset.id);
            await loadObservations();
          });
        });
      }

      async function addObservation() {
        if (!requireBasics()) return;

        const folder = getFolder();

        const observation = {
          date: document.getElementById("obsDate").value,
          minutes: document.getElementById("obsMinutes").value,
          subSeconds: document.getElementById("obsSubSeconds").value,
          notes: document.getElementById("obsNotes").value
        };

        try {
          const data = await api(`/observations?folder=${encodeURIComponent(folder)}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(observation)
          });

          renderObservations(data);
          show(data);
          await refreshStatus();
        } catch (error) {
          show({ ok: false, message: "Add observation failed", details: error.data || error.message });
        }
      }

      async function deleteObservation(id) {
        if (!requireBasics()) return;
        if (!confirm("Delete this observation entry?")) return;

        const folder = getFolder();

        try {
          const data = await api(`/delete-observation?folder=${encodeURIComponent(folder)}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id })
          });

          show(data);
        } catch (error) {
          show({ ok: false, message: "Delete observation failed", details: error.data || error.message });
        }
      }

      async function loadInfo() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          const data = await api(`/info?folder=${encodeURIComponent(folder)}`);
          fillInfoFields(data.info || {});
          show(data);
        } catch (error) {
          show({ ok: false, message: "Load info failed", details: error.data || error.message });
        }
      }

      async function generateInfo() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          generateInfoBtn.disabled = true;
          const data = await api(`/generate-info?folder=${encodeURIComponent(folder)}`);
          fillInfoFields(data.info || {});
          show({ ...data, note: "Starter info filled in. Review it, then click Save Target Info." });
        } catch (error) {
          show({ ok: false, message: "Generate info failed", details: error.data || error.message });
        } finally {
          generateInfoBtn.disabled = false;
        }
      }

      async function saveInfo() {
        if (!requireBasics()) return;

        const folder = getFolder();
        const info = collectInfoFields();

        try {
          const data = await api(`/info?folder=${encodeURIComponent(folder)}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(info)
          });

          show(data);
          await refreshStatus();
          await loadTargets();
        } catch (error) {
          show({ ok: false, message: "Save info failed", details: error.data || error.message });
        }
      }

      redeployBtn.addEventListener("click", async () => {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          redeployBtn.disabled = true;
          const data = await api("/redeploy", { method: "POST" });
          show({ ...data, note: "Redeploy requested. Wait for Cloudflare Pages to finish, then refresh the public site." });
          await refreshStatus();
        } catch (error) {
          show({ ok: false, message: "Redeploy failed", details: error.data || error.message });
        } finally {
          redeployBtn.disabled = false;
        }
      });

      folderInput.addEventListener("change", () => {
        setFolder(getFolder());
      });

      targetSelect.addEventListener("change", () => {
        if (targetSelect.value) {
          setFolder(targetSelect.value);
        }
      });

      loadTargetsBtn.addEventListener("click", loadTargets);
      useSelectedTargetBtn.addEventListener("click", useSelectedTarget);
      useNewFolderBtn.addEventListener("click", useNewFolder);

      listBtn.addEventListener("click", listFiles);
      listHiddenBtn.addEventListener("click", listHiddenFiles);
      loadInfoBtn.addEventListener("click", loadInfo);
      generateInfoBtn.addEventListener("click", generateInfo);
      saveInfoBtn.addEventListener("click", saveInfo);
      refreshStatusBtn.addEventListener("click", refreshStatus);
      addObservationBtn.addEventListener("click", addObservation);
      loadObservationsBtn.addEventListener("click", loadObservations);

      const savedFolder = localStorage.getItem(STORAGE_KEY);
      if (savedFolder) {
        setFolder(savedFolder);
      }
    </script>
  </body>
</html>

