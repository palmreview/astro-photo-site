---
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Admin | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a href="/">← Back to gallery</a>
      <h1>Photo Admin</h1>

      <section class="panel">
        <h2>Upload photo</h2>

        <label>
          Admin token
          <input id="token" type="password" placeholder="Admin token" />
        </label>

        <label>
          R2 folder
          <input id="folder" type="text" placeholder="deep-sky/M 81" />
        </label>

        <label>
          File name
          <input id="filename" type="text" placeholder="main.jpg" />
        </label>

        <label>
          Photo
          <input id="file" type="file" accept="image/*" />
        </label>

        <button id="uploadBtn">Upload</button>
      </section>

      <section class="panel">
        <h2>Hide photo</h2>

        <label>
          R2 file key
          <input id="hideKey" type="text" placeholder="deep-sky/M 81/old-photo.jpg" />
        </label>

        <button id="hideBtn">Hide photo</button>
      </section>

      <pre id="result"></pre>
    </main>

    <script define:vars={{ adminApiUrl }}>
      const result = document.getElementById("result");

      function show(message) {
        result.textContent =
          typeof message === "string" ? message : JSON.stringify(message, null, 2);
      }

      function getToken() {
        return document.getElementById("token").value.trim();
      }

      document.getElementById("uploadBtn").addEventListener("click", async () => {
        const folder = document.getElementById("folder").value.trim().replace(/\/$/, "");
        const filename = document.getElementById("filename").value.trim();
        const file = document.getElementById("file").files[0];

        if (!folder || !filename || !file) {
          show("Please enter folder, filename, and choose a file.");
          return;
        }

        const key = `${folder}/${filename}`;

        const response = await fetch(`${adminApiUrl}/upload?key=${encodeURIComponent(key)}`, {
          method: "PUT",
          headers: {
            Authorization: `Bearer ${getToken()}`,
            "Content-Type": file.type || "application/octet-stream"
          },
          body: file
        });

        show(await response.json());
      });

      document.getElementById("hideBtn").addEventListener("click", async () => {
        const key = document.getElementById("hideKey").value.trim();

        if (!key) {
          show("Please enter the R2 file key to hide.");
          return;
        }

        const response = await fetch(`${adminApiUrl}/hide`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${getToken()}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ key })
        });

        show(await response.json());
      });
    </script>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #05070d;
    color: white;
  }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 20px;
  }

  a {
    color: #9db7ff;
  }

  .panel {
    background: rgba(18, 24, 39, 0.85);
    border: 1px solid rgba(125, 162, 255, 0.25);
    border-radius: 18px;
    padding: 20px;
    margin: 22px 0;
  }

  label {
    display: grid;
    gap: 8px;
    margin-bottom: 16px;
    color: #c7d2ea;
  }

  input {
    padding: 12px;
    border-radius: 10px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #05070d;
    color: white;
  }

  button {
    padding: 12px 16px;
    border-radius: 999px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #1c2540;
    color: white;
    cursor: pointer;
  }

  pre {
    white-space: pre-wrap;
    background: #000;
    padding: 16px;
    border-radius: 12px;
    color: #9db7ff;
  }
</style>