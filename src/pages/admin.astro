---
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Admin | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a href="/">← Back to gallery</a>
      <h1>Photo Admin</h1>

      <section class="panel">
        <h2>Upload photo</h2>

        <label>
          Admin token
          <input id="token" type="password" placeholder="Admin token" />
        </label>

        <label>
          R2 folder
          <input id="folder" type="text" placeholder="deep-sky/M 81" />
        </label>

        <label>
          File name
          <input id="filename" type="text" placeholder="main.jpg" />
        </label>

        <label>
          Photo
          <input id="file" type="file" accept="image/*" />
        </label>

        <img id="preview" class="preview" alt="Upload preview" />

        <div class="button-row">
          <button id="uploadBtn" type="button">Upload</button>
          <button id="listBtn" type="button">List files in folder</button>
          <button id="redeployBtn" type="button">Redeploy Site</button>
        </div>
      </section>

      <section class="panel">
        <h2>Files in folder</h2>
        <div id="fileList" class="file-list">
          <p class="muted">Enter a folder and click “List files in folder.”</p>
        </div>
      </section>

      <pre id="result">Ready.</pre>
    </main>

    <script define:vars={{ adminApiUrl }}>
      const result = document.getElementById("result");
      const uploadBtn = document.getElementById("uploadBtn");
      const listBtn = document.getElementById("listBtn");
      const redeployBtn = document.getElementById("redeployBtn");
      const fileInput = document.getElementById("file");
      const preview = document.getElementById("preview");
      const fileList = document.getElementById("fileList");

      function show(message) {
        result.textContent =
          typeof message === "string" ? message : JSON.stringify(message, null, 2);
      }

      function getToken() {
        return document.getElementById("token").value.trim();
      }

      function getFolder() {
        return document.getElementById("folder").value.trim().replace(/\/$/, "");
      }

      async function readResponse(response) {
        const text = await response.text();

        try {
          return JSON.parse(text);
        } catch {
          return {
            ok: response.ok,
            status: response.status,
            responseText: text || "No response body"
          };
        }
      }

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];

        if (!file) {
          preview.style.display = "none";
          preview.src = "";
          return;
        }

        preview.src = URL.createObjectURL(file);
        preview.style.display = "block";
      });

      async function listFiles() {
        const token = getToken();
        const folder = getFolder();

        if (!adminApiUrl) {
          show("Missing PUBLIC_ADMIN_API_URL.");
          return;
        }

        if (!token) {
          show("Please enter your admin token.");
          return;
        }

        if (!folder) {
          show("Please enter a folder.");
          return;
        }

        try {
          listBtn.disabled = true;
          listBtn.textContent = "Listing...";
          show(`Listing files in ${folder}...`);

          const response = await fetch(
            `${adminApiUrl}/list?folder=${encodeURIComponent(folder)}`,
            {
              method: "GET",
              headers: {
                Authorization: `Bearer ${token}`
              }
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "List failed",
              status: response.status,
              details: data
            });
            return;
          }

          renderFileList(data.files || []);
          show(data);
        } catch (error) {
          show(`List failed: ${error.message}`);
        } finally {
          listBtn.disabled = false;
          listBtn.textContent = "List files in folder";
        }
      }

      function renderFileList(files) {
        if (!files.length) {
          fileList.innerHTML =
            `<p class="muted">No image files found in this folder.</p>`;
          return;
        }

        fileList.innerHTML = files
          .map(
            (file) => `
              <div class="file-card">
                <img src="${file.url}" alt="${file.filename}" />
                <div class="file-info">
                  <strong>${file.filename}</strong>
                  <code>${file.key}</code>
                  <a href="${file.url}" target="_blank" rel="noopener noreferrer">View full image</a>
                </div>
                <button class="hide-file-btn" data-key="${file.key}" type="button">Hide</button>
              </div>
            `
          )
          .join("");

        document.querySelectorAll(".hide-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await hideFile(button.dataset.key);
            await listFiles();
          });
        });
      }

      async function hideFile(key) {
        const token = getToken();

        if (!confirm(`Hide this file?\n\n${key}`)) {
          return;
        }

        try {
          show(`Hiding ${key}...`);

          const response = await fetch(`${adminApiUrl}/hide`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json"
            },
            body: JSON.stringify({ key })
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Hide failed",
              status: response.status,
              details: data
            });
            return;
          }

          show(data);
        } catch (error) {
          show(`Hide failed: ${error.message}`);
        }
      }

      uploadBtn.addEventListener("click", async () => {
        const token = getToken();
        const folder = getFolder();
        const filename = document.getElementById("filename").value.trim();
        const file = fileInput.files[0];

        if (!adminApiUrl) {
          show("Missing PUBLIC_ADMIN_API_URL.");
          return;
        }

        if (!token) {
          show("Please enter your admin token.");
          return;
        }

        if (!folder || !filename || !file) {
          show("Please enter folder, filename, and choose a file.");
          return;
        }

        const key = `${folder}/${filename}`;

        try {
          uploadBtn.disabled = true;
          uploadBtn.textContent = "Uploading...";
          show(`Uploading ${key}...`);

          const response = await fetch(
            `${adminApiUrl}/upload?key=${encodeURIComponent(key)}`,
            {
              method: "PUT",
              headers: {
                Authorization: `Bearer ${token}`,
                "Content-Type": file.type || "application/octet-stream"
              },
              body: file
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Upload failed",
              status: response.status,
              details: data
            });
            return;
          }

          show(data);
          await listFiles();
        } catch (error) {
          show(`Upload failed: ${error.message}`);
        } finally {
          uploadBtn.disabled = false;
          uploadBtn.textContent = "Upload";
        }
      });

      redeployBtn.addEventListener("click", async () => {
        const token = getToken();

        if (!adminApiUrl) {
          show("Missing PUBLIC_ADMIN_API_URL.");
          return;
        }

        if (!token) {
          show("Please enter your admin token.");
          return;
        }

        try {
          redeployBtn.disabled = true;
          redeployBtn.textContent = "Redeploying...";
          show("Requesting site redeploy...");

          const response = await fetch(`${adminApiUrl}/redeploy`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Redeploy failed",
              status: response.status,
              details: data
            });
            return;
          }

          show({
            ...data,
            note: "Redeploy requested. Wait for Cloudflare Pages to finish, then refresh the public site."
          });
        } catch (error) {
          show(`Redeploy failed: ${error.message}`);
        } finally {
          redeployBtn.disabled = false;
          redeployBtn.textContent = "Redeploy Site";
        }
      });

      listBtn.addEventListener("click", listFiles);
    </script>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #05070d;
    color: white;
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 20px;
  }

  a {
    color: #9db7ff;
  }

  .panel {
    background: rgba(18, 24, 39, 0.85);
    border: 1px solid rgba(125, 162, 255, 0.25);
    border-radius: 18px;
    padding: 20px;
    margin: 22px 0;
  }

  label {
    display: grid;
    gap: 8px;
    margin-bottom: 16px;
    color: #c7d2ea;
  }

  input {
    padding: 12px;
    border-radius: 10px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #05070d;
    color: white;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  button {
    padding: 12px 16px;
    border-radius: 999px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #1c2540;
    color: white;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.55;
    cursor: wait;
  }

  .preview {
    display: none;
    max-width: 260px;
    max-height: 260px;
    object-fit: contain;
    background: black;
    border-radius: 12px;
    margin-bottom: 16px;
    border: 1px solid rgba(125, 162, 255, 0.25);
  }

  .file-list {
    display: grid;
    gap: 12px;
  }

  .file-card {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    gap: 14px;
    align-items: center;
    background: rgba(5, 7, 13, 0.65);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 12px;
  }

  .file-card img {
    width: 90px;
    height: 70px;
    object-fit: cover;
    background: black;
    border-radius: 8px;
  }

  .file-info {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .file-info code {
    color: #c7d2ea;
    font-size: 12px;
    overflow-wrap: anywhere;
  }

  .muted {
    color: #9db7ff;
  }

  pre {
    white-space: pre-wrap;
    background: #000;
    padding: 16px;
    border-radius: 12px;
    color: #9db7ff;
  }

  @media (max-width: 640px) {
    .file-card {
      grid-template-columns: 1fr;
    }

    .file-card img {
      width: 100%;
      height: 180px;
    }
  }
</style>