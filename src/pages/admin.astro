---
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Admin | Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <a href="/">← Back to gallery</a>
      <h1>Photo Admin</h1>

      <section class="panel status-panel">
        <div class="panel-header">
          <h2>Site Status</h2>
          <button id="refreshStatusBtn" type="button">Refresh Status</button>
        </div>

        <div id="statusGrid" class="status-grid">
          <p class="muted">Enter your admin token and refresh status.</p>
        </div>
      </section>

      <section class="panel">
        <h2>Upload photo</h2>

        <label>
          Admin token
          <input id="token" type="password" placeholder="Admin token" />
        </label>

        <label>
          R2 folder
          <input id="folder" type="text" placeholder="deep-sky/M 81" />
        </label>

        <label>
          File name
          <input id="filename" type="text" placeholder="main.jpg" />
        </label>

        <label>
          Photo
          <input id="file" type="file" accept="image/*" />
        </label>

        <img id="preview" class="preview" alt="Upload preview" />

        <div class="button-row">
          <button id="uploadBtn" type="button">Upload</button>
          <button id="listBtn" type="button">List files in folder</button>
          <button id="loadInfoBtn" type="button">Load Target Info</button>
          <button id="redeployBtn" type="button">Redeploy Site</button>
        </div>
      </section>

      <section class="panel">
        <h2>Files in folder</h2>
        <div id="fileList" class="file-list">
          <p class="muted">Enter a folder and click “List files in folder.”</p>
        </div>
      </section>

      <section class="panel">
        <h2>Target Info Editor</h2>
        <p class="muted">
          This saves an <code>info.json</code> file inside the selected R2 folder.
        </p>

        <div class="form-grid">
          <label>
            Name
            <input id="infoName" type="text" placeholder="Bode's Galaxy" />
          </label>

          <label>
            Catalog
            <input id="infoCatalog" type="text" placeholder="M81" />
          </label>

          <label>
            Category
            <input id="infoCategory" type="text" placeholder="Deep Sky" />
          </label>

          <label>
            Distance
            <input id="infoDistance" type="text" placeholder="~12 million light-years" />
          </label>

          <label>
            Date Captured
            <input id="infoDateCaptured" type="text" placeholder="June 2026" />
          </label>

          <label>
            Equipment
            <input id="infoEquipment" type="text" placeholder="Seestar S30" />
          </label>

          <label>
            Location
            <input id="infoLocation" type="text" placeholder="Florida, USA" />
          </label>
        </div>

        <label>
          Short Description
          <textarea id="infoShortDescription" rows="2"></textarea>
        </label>

        <label>
          Description
          <textarea id="infoDescription" rows="4"></textarea>
        </label>

        <label>
          What you're looking at
          <textarea id="infoWhatYouAreSeeing" rows="4"></textarea>
        </label>

        <label>
          Why it is interesting
          <textarea id="infoWhyItIsInteresting" rows="4"></textarea>
        </label>

        <label>
          Capture Notes
          <textarea id="infoCaptureNotes" rows="4"></textarea>
        </label>

        <div class="button-row">
          <button id="saveInfoBtn" type="button">Save Target Info</button>
        </div>
      </section>

      <pre id="result">Ready.</pre>
    </main>

    <script define:vars={{ adminApiUrl }}>
      const result = document.getElementById("result");
      const statusGrid = document.getElementById("statusGrid");

      const uploadBtn = document.getElementById("uploadBtn");
      const listBtn = document.getElementById("listBtn");
      const loadInfoBtn = document.getElementById("loadInfoBtn");
      const saveInfoBtn = document.getElementById("saveInfoBtn");
      const redeployBtn = document.getElementById("redeployBtn");
      const refreshStatusBtn = document.getElementById("refreshStatusBtn");

      const fileInput = document.getElementById("file");
      const preview = document.getElementById("preview");
      const fileList = document.getElementById("fileList");

      const infoFields = {
        name: document.getElementById("infoName"),
        catalog: document.getElementById("infoCatalog"),
        category: document.getElementById("infoCategory"),
        distance: document.getElementById("infoDistance"),
        dateCaptured: document.getElementById("infoDateCaptured"),
        equipment: document.getElementById("infoEquipment"),
        location: document.getElementById("infoLocation"),
        shortDescription: document.getElementById("infoShortDescription"),
        description: document.getElementById("infoDescription"),
        whatYouAreSeeing: document.getElementById("infoWhatYouAreSeeing"),
        whyItIsInteresting: document.getElementById("infoWhyItIsInteresting"),
        captureNotes: document.getElementById("infoCaptureNotes")
      };

      function show(message) {
        result.textContent =
          typeof message === "string" ? message : JSON.stringify(message, null, 2);
      }

      function getToken() {
        return document.getElementById("token").value.trim();
      }

      function getFolder() {
        return document.getElementById("folder").value.trim().replace(/\/$/, "");
      }

      function requireBasics({ requireFolder = true } = {}) {
        if (!adminApiUrl) {
          show("Missing PUBLIC_ADMIN_API_URL.");
          return false;
        }

        if (!getToken()) {
          show("Please enter your admin token.");
          return false;
        }

        if (requireFolder && !getFolder()) {
          show("Please enter a folder.");
          return false;
        }

        return true;
      }

      async function readResponse(response) {
        const text = await response.text();

        try {
          return JSON.parse(text);
        } catch {
          return {
            ok: response.ok,
            status: response.status,
            responseText: text || "No response body"
          };
        }
      }

      function formatDate(value) {
        if (!value) return "Never";

        try {
          return new Date(value).toLocaleString();
        } catch {
          return value;
        }
      }

      function renderStatus(status) {
        statusGrid.innerHTML = `
          <div class="status-card">
            <span>Last redeploy requested</span>
            <strong>${formatDate(status.lastRedeployRequestedAt)}</strong>
          </div>

          <div class="status-card">
            <span>Last redeploy status</span>
            <strong>${status.lastRedeployStatus || "Unknown"}</strong>
          </div>

          <div class="status-card">
            <span>Last upload</span>
            <strong>${formatDate(status.lastUploadAt)}</strong>
            <code>${status.lastUploadKey || ""}</code>
          </div>

          <div class="status-card">
            <span>Last hidden file</span>
            <strong>${formatDate(status.lastHideAt)}</strong>
            <code>${status.lastHideKey || ""}</code>
          </div>

          <div class="status-card">
            <span>Last info save</span>
            <strong>${formatDate(status.lastInfoSaveAt)}</strong>
            <code>${status.lastInfoFolder || ""}</code>
          </div>
        `;
      }

      async function refreshStatus() {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          refreshStatusBtn.disabled = true;
          refreshStatusBtn.textContent = "Refreshing...";

          const response = await fetch(`${adminApiUrl}/status`, {
            method: "GET",
            headers: {
              Authorization: `Bearer ${getToken()}`
            }
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({ ok: false, message: "Status failed", details: data });
            return;
          }

          renderStatus(data.status || {});
          show(data);
        } catch (error) {
          show(`Status failed: ${error.message}`);
        } finally {
          refreshStatusBtn.disabled = false;
          refreshStatusBtn.textContent = "Refresh Status";
        }
      }

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];

        if (!file) {
          preview.style.display = "none";
          preview.src = "";
          return;
        }

        preview.src = URL.createObjectURL(file);
        preview.style.display = "block";
      });

      async function listFiles() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          listBtn.disabled = true;
          listBtn.textContent = "Listing...";
          show(`Listing files in ${folder}...`);

          const response = await fetch(
            `${adminApiUrl}/list?folder=${encodeURIComponent(folder)}`,
            {
              method: "GET",
              headers: {
                Authorization: `Bearer ${getToken()}`
              }
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "List failed",
              status: response.status,
              details: data
            });
            return;
          }

          renderFileList(data.files || []);
          show(data);
        } catch (error) {
          show(`List failed: ${error.message}`);
        } finally {
          listBtn.disabled = false;
          listBtn.textContent = "List files in folder";
        }
      }

      function renderFileList(files) {
        if (!files.length) {
          fileList.innerHTML =
            `<p class="muted">No image files found in this folder.</p>`;
          return;
        }

        fileList.innerHTML = files
          .map(
            (file) => `
              <div class="file-card">
                <img src="${file.url}" alt="${file.filename}" />
                <div class="file-info">
                  <strong>${file.filename}</strong>
                  <code>${file.key}</code>
                  <a href="${file.url}" target="_blank" rel="noopener noreferrer">View full image</a>
                </div>
                <button class="hide-file-btn" data-key="${file.key}" type="button">Hide</button>
              </div>
            `
          )
          .join("");

        document.querySelectorAll(".hide-file-btn").forEach((button) => {
          button.addEventListener("click", async () => {
            await hideFile(button.dataset.key);
            await listFiles();
            await refreshStatus();
          });
        });
      }

      async function hideFile(key) {
        if (!confirm(`Hide this file?\n\n${key}`)) return;

        try {
          show(`Hiding ${key}...`);

          const response = await fetch(`${adminApiUrl}/hide`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${getToken()}`,
              "Content-Type": "application/json"
            },
            body: JSON.stringify({ key })
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Hide failed",
              status: response.status,
              details: data
            });
            return;
          }

          show(data);
        } catch (error) {
          show(`Hide failed: ${error.message}`);
        }
      }

      uploadBtn.addEventListener("click", async () => {
        if (!requireBasics()) return;

        const folder = getFolder();
        const filename = document.getElementById("filename").value.trim();
        const file = fileInput.files[0];

        if (!filename || !file) {
          show("Please enter filename and choose a file.");
          return;
        }

        const key = `${folder}/${filename}`;

        try {
          uploadBtn.disabled = true;
          uploadBtn.textContent = "Uploading...";
          show(`Uploading ${key}...`);

          const response = await fetch(
            `${adminApiUrl}/upload?key=${encodeURIComponent(key)}`,
            {
              method: "PUT",
              headers: {
                Authorization: `Bearer ${getToken()}`,
                "Content-Type": file.type || "application/octet-stream"
              },
              body: file
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Upload failed",
              status: response.status,
              details: data
            });
            return;
          }

          show(data);
          await listFiles();
          await refreshStatus();
        } catch (error) {
          show(`Upload failed: ${error.message}`);
        } finally {
          uploadBtn.disabled = false;
          uploadBtn.textContent = "Upload";
        }
      });

      async function loadInfo() {
        if (!requireBasics()) return;

        const folder = getFolder();

        try {
          loadInfoBtn.disabled = true;
          loadInfoBtn.textContent = "Loading...";

          const response = await fetch(
            `${adminApiUrl}/info?folder=${encodeURIComponent(folder)}`,
            {
              method: "GET",
              headers: {
                Authorization: `Bearer ${getToken()}`
              }
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Load info failed",
              status: response.status,
              details: data
            });
            return;
          }

          const info = data.info || {};

          Object.entries(infoFields).forEach(([key, element]) => {
            element.value = info[key] || "";
          });

          show(data);
        } catch (error) {
          show(`Load info failed: ${error.message}`);
        } finally {
          loadInfoBtn.disabled = false;
          loadInfoBtn.textContent = "Load Target Info";
        }
      }

      async function saveInfo() {
        if (!requireBasics()) return;

        const folder = getFolder();

        const info = {};
        Object.entries(infoFields).forEach(([key, element]) => {
          info[key] = element.value.trim();
        });

        try {
          saveInfoBtn.disabled = true;
          saveInfoBtn.textContent = "Saving...";
          show(`Saving info.json in ${folder}...`);

          const response = await fetch(
            `${adminApiUrl}/info?folder=${encodeURIComponent(folder)}`,
            {
              method: "PUT",
              headers: {
                Authorization: `Bearer ${getToken()}`,
                "Content-Type": "application/json"
              },
              body: JSON.stringify(info)
            }
          );

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Save info failed",
              status: response.status,
              details: data
            });
            return;
          }

          show(data);
          await refreshStatus();
        } catch (error) {
          show(`Save info failed: ${error.message}`);
        } finally {
          saveInfoBtn.disabled = false;
          saveInfoBtn.textContent = "Save Target Info";
        }
      }

      redeployBtn.addEventListener("click", async () => {
        if (!requireBasics({ requireFolder: false })) return;

        try {
          redeployBtn.disabled = true;
          redeployBtn.textContent = "Redeploying...";
          show("Requesting site redeploy...");

          const response = await fetch(`${adminApiUrl}/redeploy`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${getToken()}`
            }
          });

          const data = await readResponse(response);

          if (!response.ok) {
            show({
              ok: false,
              message: "Redeploy failed",
              status: response.status,
              details: data
            });
            return;
          }

          show({
            ...data,
            note: "Redeploy requested. Wait for Cloudflare Pages to finish, then refresh the public site."
          });

          await refreshStatus();
        } catch (error) {
          show(`Redeploy failed: ${error.message}`);
        } finally {
          redeployBtn.disabled = false;
          redeployBtn.textContent = "Redeploy Site";
        }
      });

      listBtn.addEventListener("click", listFiles);
      loadInfoBtn.addEventListener("click", loadInfo);
      saveInfoBtn.addEventListener("click", saveInfo);
      refreshStatusBtn.addEventListener("click", refreshStatus);
    </script>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #05070d;
    color: white;
  }

  main {
    max-width: 980px;
    margin: 0 auto;
    padding: 32px 20px;
  }

  a {
    color: #9db7ff;
  }

  .panel {
    background: rgba(18, 24, 39, 0.85);
    border: 1px solid rgba(125, 162, 255, 0.25);
    border-radius: 18px;
    padding: 20px;
    margin: 22px 0;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  label {
    display: grid;
    gap: 8px;
    margin-bottom: 16px;
    color: #c7d2ea;
  }

  input,
  textarea {
    padding: 12px;
    border-radius: 10px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #05070d;
    color: white;
    font: inherit;
  }

  textarea {
    resize: vertical;
  }

  code {
    color: #9db7ff;
  }

  .form-grid,
  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .status-card {
    background: rgba(5, 7, 13, 0.65);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 14px;
    display: grid;
    gap: 5px;
  }

  .status-card span {
    color: #9db7ff;
    font-size: 13px;
  }

  .status-card strong {
    color: white;
    font-size: 15px;
  }

  .status-card code {
    font-size: 12px;
    overflow-wrap: anywhere;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  button {
    padding: 12px 16px;
    border-radius: 999px;
    border: 1px solid rgba(125, 162, 255, 0.35);
    background: #1c2540;
    color: white;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.55;
    cursor: wait;
  }

  .preview {
    display: none;
    max-width: 260px;
    max-height: 260px;
    object-fit: contain;
    background: black;
    border-radius: 12px;
    margin-bottom: 16px;
    border: 1px solid rgba(125, 162, 255, 0.25);
  }

  .file-list {
    display: grid;
    gap: 12px;
  }

  .file-card {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    gap: 14px;
    align-items: center;
    background: rgba(5, 7, 13, 0.65);
    border: 1px solid rgba(125, 162, 255, 0.18);
    border-radius: 14px;
    padding: 12px;
  }

  .file-card img {
    width: 90px;
    height: 70px;
    object-fit: cover;
    background: black;
    border-radius: 8px;
  }

  .file-info {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .file-info code {
    color: #c7d2ea;
    font-size: 12px;
    overflow-wrap: anywhere;
  }

  .muted {
    color: #9db7ff;
  }

  pre {
    white-space: pre-wrap;
    background: #000;
    padding: 16px;
    border-radius: 12px;
    color: #9db7ff;
  }

  @media (max-width: 640px) {
    .panel-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .file-card {
      grid-template-columns: 1fr;
    }

    .file-card img {
      width: 100%;
      height: 180px;
    }
  }
</style>