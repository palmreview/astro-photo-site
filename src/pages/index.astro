---
import targetsData from "../data/targets.json";
import { getImagesForFolder } from "../lib/r2-images.js";

const targets = await Promise.all(
  targetsData.map(async (target) => {
    const images = await getImagesForFolder(target.folder);

    return {
      ...target,
      imageUrl: images[0]?.url,
      photoCount: images.length
    };
  })
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Andrew's Astro Photos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">Beginner astrophotography gallery</p>
        <h1>Andrew's Astro Photos</h1>
        <p>
          A simple, beginner-friendly collection of space photos captured while learning the night sky.
        </p>
      </section>

      <section class="grid">
        {targets.map((target) => (
          <a class="card" href={`/targets/${target.slug}/`}>
            <div class="image-wrapper">
              {target.imageUrl ? (
                <img src={target.imageUrl} alt={target.name} />
              ) : (
                <div class="missing-image">No photos found</div>
              )}
            </div>

            <div class="card-content">
              <p class="category">{target.category}</p>
              <h2>
                {target.catalog ? `${target.catalog}: ${target.name}` : target.name}
              </h2>
              <p class="desc">{target.shortDescription}</p>

              <p class="photo-count">
                {target.photoCount === 1 ? "1 photo" : `${target.photoCount} photos`}
              </p>
            </div>
          </a>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #0c1222, #05070d);
    color: white;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .hero {
    margin-bottom: 40px;
  }

  .eyebrow {
    color: #7da2ff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    margin: 0 0 10px;
  }

  h1 {
    font-size: 46px;
    margin: 0 0 12px;
  }

  .hero p {
    color: #b8c4e0;
    font-size: 18px;
    max-width: 720px;
    line-height: 1.5;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 26px;
  }

  .card {
    background: rgba(18, 24, 39, 0.75);
    border: 1px solid rgba(125, 162, 255, 0.22);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    color: white;
  }

  .image-wrapper {
    height: 230px;
    overflow: hidden;
    background: black;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .missing-image {
    height: 100%;
    display: grid;
    place-items: center;
    color: #9db7ff;
    font-size: 14px;
  }

  .card-content {
    padding: 18px;
  }

  .category {
    color: #9db7ff;
    font-size: 13px;
    margin: 0 0 8px;
  }

  h2 {
    margin: 0 0 10px;
    font-size: 21px;
  }

  .desc {
    color: #c7d2ea;
    font-size: 15px;
    line-height: 1.45;
    margin: 0;
  }

  .photo-count {
    color: #9db7ff;
    font-size: 13px;
    margin-top: 14px;
  }
</style>